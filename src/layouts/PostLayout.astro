---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    author?: string;
    description?: string;
    tags?: string[];
  };
  lastModified?: string | null;
}

const { frontmatter, lastModified } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <h1>{frontmatter.title}</h1>
    <div class="post-meta">
      {frontmatter.author && <span><a href={`/authors/${frontmatter.author}`} class="subtle-link">{frontmatter.author}</a></span>}
      <time>{formattedDate}</time>
      {lastModified && lastModified !== formattedDate && (
        <span class="updated">Updated {lastModified}</span>
      )}
    </div>
    {
      frontmatter.tags && (
        <div class="post-tags">
          {frontmatter.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )
    }

    <slot />
  </article>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.8rem;
  }

  .post-meta span:not(:last-child)::after,
  .post-meta time:not(:last-child)::after {
    content: '·';
    margin-left: 0.5rem;
  }

  .updated {
    font-style: italic;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }

  .post-tags .tag {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    background: var(--color-sidebar-bg);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .post-tags .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
