---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    author?: string;
    description?: string;
    tags?: string[];
  };
  lastModified?: string | null;
}

const { frontmatter, lastModified } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <h1>{frontmatter.title}</h1>
    <div class="post-meta">
      <time>{formattedDate}</time>
      {frontmatter.author && <span> &middot; {frontmatter.author}</span>}
      {lastModified && lastModified !== formattedDate && (
        <span> &middot; Updated {lastModified}</span>
      )}
      {
        frontmatter.tags && (
          <span class="tags">
            {' '}&middot; <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>{' '}
            {frontmatter.tags.join(', ')}
          </span>
        )
      }
    </div>

    <slot />
  </article>
</BaseLayout>
