---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Learning ML, one token at a time.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | token by token</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Merriweather:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
      crossorigin="anonymous"
    />

    <style>
      @import '../styles/global.css';
    </style>
    <style is:global>
      .post-subtitle,
      .post-subtitle * {
        font-family: 'Inter', -apple-system, sans-serif !important;
        font-weight: 200 !important;
        font-size: 0.85rem !important;
        color: var(--color-text-muted);
        line-height: 1.8;
        letter-spacing: 0.02em;
      }
      .post-subtitle svg {
        width: 12px !important;
        height: 12px !important;
        display: inline-block;
        vertical-align: -1px;
        margin-right: 2px;
        opacity: 0.5;
      }
      a:visited {
        color: var(--color-link);
      }
      .post-title:visited {
        color: var(--color-text);
      }
      .topbar-nav a:visited {
        color: var(--color-text-muted);
      }
      .topbar-nav a.active:visited {
        color: var(--color-accent);
      }

      /* Home two-column layout */
      .home-content {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        max-width: 1400px;
        margin: 0 auto;
        padding: 3rem;
      }
      .home-main { min-width: 0; }
      .home-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding-top: 0.5rem;
      }
      .sidebar-card {
        padding: 1.2rem;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-card-bg);
      }
      .sidebar-card h3 {
        font-family: 'Inter', -apple-system, sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-text-muted);
        margin: 0 0 0.8rem;
      }
      .sidebar-card p {
        font-size: 0.88rem;
        margin-bottom: 0.6rem;
      }
      .sidebar-link {
        font-family: 'Inter', -apple-system, sans-serif;
        font-size: 0.82rem;
        text-decoration: none;
      }
      .sidebar-tags, .sidebar-authors {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }
      .tag-pill, .author-pill {
        font-family: 'Inter', -apple-system, sans-serif;
        font-size: 0.75rem;
        color: var(--color-text-muted);
        background: var(--color-sidebar-bg);
        border: 1px solid var(--color-border);
        border-radius: 3px;
        padding: 0.2rem 0.6rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: border-color 0.2s, color 0.2s;
      }
      .tag-pill:hover, .author-pill:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
      }
      .pill-count { font-size: 0.65rem; opacity: 0.6; }
      .author-pill svg { width: 14px !important; height: 14px !important; opacity: 0.5; }
      .not-by-ai-sidebar img {
        width: 120px;
        height: auto;
        margin: 0;
        border-radius: 0;
        opacity: 0.8;
      }
      .not-by-ai-sidebar:hover img { opacity: 1; }
      .subtle-link {
        color: var(--color-text-muted) !important;
        text-decoration: none !important;
      }
      .subtle-link:hover {
        color: var(--color-accent) !important;
        text-decoration: underline !important;
      }
      @media (max-width: 900px) {
        .home-content {
          grid-template-columns: 1fr;
          padding: 2rem 1.2rem;
        }
      }
    </style>

    <!-- Theme: apply before render to prevent flash -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>
  </head>
  <body>
    <header class="topbar">
      <a href="/" class="topbar-brand">
        <img src="/logo.png" alt="token by token" class="topbar-logo" />
        <span class="topbar-name">token by token</span>
      </a>
      <div class="topbar-right">
        <nav class="topbar-nav">
          <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
          <a href="/posts" class:list={[{ active: currentPath.startsWith('/posts') }]}>Posts</a>
          <a href="/about" class:list={[{ active: currentPath === '/about/' || currentPath === '/about' }]}>About</a>
        </nav>
        <button class="theme-toggle" aria-label="Toggle theme" id="theme-toggle">
          <span class="light-only">&#9789;</span>
          <span class="dark-only">&#9788;</span>
        </button>
        <a href="https://github.com/danielquillanroxas/token-by-token" class="topbar-github" target="_blank" rel="noopener" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <button class="burger" aria-label="Menu">&#9776;</button>
      </div>
    </header>

    <!-- Mobile menu -->
    <div class="mobile-menu">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
      <a href="/posts" class:list={[{ active: currentPath.startsWith('/posts') }]}>Posts</a>
      <a href="/about" class:list={[{ active: currentPath === '/about/' || currentPath === '/about' }]}>About</a>
      <a href="https://github.com/danielquillanroxas/token-by-token" target="_blank" rel="noopener">GitHub</a>
    </div>

    <!-- Home page: full width, you control the layout -->
    <div class="home-wrapper">
      <slot />
    </div>

    <footer class="site-footer" style="max-width: var(--content-width); margin: 0 auto; padding: 0 3rem 3rem;">
      <div class="footer-row">
        <p>token by token &mdash; learning in public</p>
        <a href="https://notbyai.fyi/hi/token-by-token/" target="_blank" rel="noopener" class="not-by-ai">
          <img src="/not-by-ai-dark.png" alt="Written by Humans, Not by AI" class="light-only" />
          <img src="/not-by-ai-light.png" alt="Written by Humans, Not by AI" class="dark-only" />
        </a>
        <a href="https://github.com/danielquillanroxas/token-by-token" target="_blank" rel="noopener" class="footer-github" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </footer>

    <script>
      const burger = document.querySelector('.burger');
      const mobileMenu = document.querySelector('.mobile-menu');

      burger?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('open');
      });

      document.addEventListener('click', (e) => {
        if (mobileMenu?.classList.contains('open')) {
          if (!mobileMenu.contains(e.target as Node) && e.target !== burger) {
            mobileMenu.classList.remove('open');
          }
        }
      });

      // Theme toggle
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
      });
    </script>
  </body>
</html>
