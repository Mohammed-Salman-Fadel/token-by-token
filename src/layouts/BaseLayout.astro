---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Learning ML, one token at a time.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | token by token</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Merriweather:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
      crossorigin="anonymous"
    />

    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <div class="site-wrapper">
      <button class="sidebar-toggle" aria-label="Toggle sidebar">&#9776;</button>
      <aside class="sidebar">
        <a href="/" class="sidebar-title">token by token</a>
        <div class="sidebar-subtitle">ML notes & explorations</div>

        <div class="sidebar-section-title">Navigation</div>
        <nav>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </nav>

        <div class="sidebar-section-title">Topics</div>
        <nav>
          <ul>
            <li><a href="/posts">All Posts</a></li>
          </ul>
        </nav>
      </aside>

      <main class="main-content">
        <slot />

        <footer class="site-footer">
          <p>token by token &mdash; learning in public</p>
        </footer>
      </main>
    </div>
    <script>
      const toggle = document.querySelector('.sidebar-toggle');
      const sidebar = document.querySelector('.sidebar');
      const wrapper = document.querySelector('.site-wrapper');
      const sidebarWidth = 260;
      const minContentWidth = 600;

      function checkSpace() {
        const isTight = window.innerWidth < sidebarWidth + minContentWidth;
        if (isTight) {
          sidebar?.classList.add('auto-hidden');
          document.body.classList.add('compact-mode');
        } else if (!sidebar?.classList.contains('hidden')) {
          sidebar?.classList.remove('auto-hidden', 'mobile-open');
          document.body.classList.remove('compact-mode');
        }
      }

      checkSpace();
      window.addEventListener('resize', checkSpace);

      toggle?.addEventListener('click', () => {
        if (sidebar?.classList.contains('auto-hidden')) {
          sidebar.classList.toggle('mobile-open');
        } else {
          sidebar?.classList.toggle('hidden');
        }
      });

      document.addEventListener('click', (e) => {
        if (sidebar?.classList.contains('mobile-open')) {
          if (!sidebar.contains(e.target as Node) && e.target !== toggle) {
            sidebar.classList.remove('mobile-open');
          }
        }
      });
    </script>
  </body>
</html>
