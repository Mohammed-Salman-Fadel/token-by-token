---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Home">
  <section class="hero">
    <p class="tagline">
      Notes on machine learning, NLP, and everything in between.<br />
      Learning in public, one concept at a time.
    </p>
  </section>

  <h2>Recent posts</h2>

  {
    posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <div class="post-item">
            <a href={`/posts/${post.id}`} class="post-title">{post.data.title}</a>
            <div class="post-item-meta">
              {post.data.author && <span class="post-author">{post.data.author}</span>}
              <time>
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              {post.data.tags && (
                <span class="post-item-tags">
                  {post.data.tags.join(', ')}
                </span>
              )}
            </div>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
          </div>
        ))}
      </div>
    ) : (
      <p>No posts yet. Check back soon!</p>
    )
  }
</BaseLayout>
