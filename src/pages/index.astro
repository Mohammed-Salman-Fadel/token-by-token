---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getCollection } from 'astro:content';
import { execSync } from 'child_process';

const posts = (await getCollection('posts')).sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Build tag counts
const tagCounts = new Map<string, number>();
posts.forEach((p) => {
  (p.data.tags || []).forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);

// Build author counts
const authorCounts = new Map<string, number>();
posts.forEach((p) => {
  if (p.data.author) {
    authorCounts.set(p.data.author, (authorCounts.get(p.data.author) || 0) + 1);
  }
});
const authors = [...authorCounts.entries()].sort((a, b) => b[1] - a[1]);

// Latest git commit
let latestCommit = { message: '', date: '', hash: '' };
try {
  const log = execSync('git log -1 --format=%s|||%cI|||%h').toString().trim();
  const [message, date, hash] = log.split('|||');
  latestCommit = {
    message: message.length > 50 ? message.slice(0, 50) + '...' : message,
    date: new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
    hash,
  };
} catch {}

// Activity timeline (last 5 posts)
const recentActivity = posts.slice(0, 5);
---

<HomeLayout title="Home">
  <div class="home-content">
    <!-- Main column -->
    <div class="home-main">
      <section class="hero">
        <p class="tagline">
          Notes on machine learning, NLP, and everything in between.<br />
          Learning in public, one concept at a time.
        </p>
      </section>

      <!-- Stats -->
      <div class="stats-bar">
        <div class="stat">
          <span class="stat-number">{posts.length}</span>
          <span class="stat-label">posts</span>
        </div>
        <div class="stat">
          <span class="stat-number">{tags.length}</span>
          <span class="stat-label">topics</span>
        </div>
        <div class="stat">
          <span class="stat-number">{authors.length}</span>
          <span class="stat-label">authors</span>
        </div>
      </div>

      <!-- Search -->
      <div class="search-wrapper">
        <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="search-input" placeholder="Search posts..." class="search-input" />
      </div>

      <h2>Recent posts</h2>

      {
        posts.length > 0 ? (
          <div class="post-list" id="post-list">
            {posts.map((post) => (
              <div class="post-item" data-title={post.data.title.toLowerCase()} data-tags={(post.data.tags || []).join(' ').toLowerCase()} data-author={(post.data.author || '').toLowerCase()} data-desc={(post.data.description || '').toLowerCase()}>
                <a href={`/posts/${post.id}`} class="post-title">{post.data.title}</a>
                <div class="post-subtitle">
                  {post.data.author && (
                    <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <a href={`/authors/${post.data.author}`} class="subtle-link">{post.data.author}</a></span>
                  )}
                  {post.data.author && <span> &middot; </span>}
                  <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                  {post.data.tags && (
                    <span> &middot; <svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg> {post.data.tags.map((tag, i) => (
                      <span><a href={`/tags/${tag}`} class="subtle-link">{tag}</a>{i < post.data.tags!.length - 1 ? ', ' : ''}</span>
                    ))}</span>
                  )}
                  {post.data.description && <br />}
                  {post.data.description && <span>{post.data.description}</span>}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p>No posts yet. Check back soon!</p>
        )
      }
    </div>

    <!-- Sidebar -->
    <aside class="home-sidebar">
      <div class="sidebar-card">
        <h3>About</h3>
        <p>Two humans learning ML in public. We write to understand, and publish to stay accountable.</p>
        <a href="/about" class="sidebar-link">Read more &rarr;</a>
      </div>

      {authors.length > 0 && (
        <div class="sidebar-card">
          <h3>Authors</h3>
          <div class="sidebar-authors">
            {authors.map(([author, count]) => (
              <a href={`/authors/${author}`} class="author-pill">
                <svg width="14" height="14" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                {author} <span class="pill-count">{count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {tags.length > 0 && (
        <div class="sidebar-card">
          <h3>Topics</h3>
          <div class="sidebar-tags">
            {tags.map(([tag, count]) => (
              <a href={`/tags/${tag}`} class="tag-pill">
                {tag} <span class="pill-count">{count}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Activity timeline -->
      {recentActivity.length > 0 && (
        <div class="sidebar-card">
          <h3>Activity</h3>
          <div class="activity-timeline">
            {recentActivity.map((post) => (
              <div class="activity-item">
                <div class="activity-dot" />
                <div class="activity-text">
                  <span class="activity-author">{post.data.author || 'Anonymous'}</span> published <a href={`/posts/${post.id}`} class="subtle-link">{post.data.title}</a>
                  <span class="activity-date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Latest commit -->
      {latestCommit.hash && (
        <div class="sidebar-card">
          <h3>Latest update</h3>
          <div class="latest-commit">
            <a href={`https://github.com/danielquillanroxas/token-by-token/commit/${latestCommit.hash}`} target="_blank" rel="noopener" class="subtle-link commit-msg">{latestCommit.message}</a>
            <span class="commit-meta">{latestCommit.hash} &middot; {latestCommit.date}</span>
          </div>
        </div>
      )}

      <!-- Newsletter -->
      <div class="sidebar-card">
        <h3>Newsletter</h3>
        <p>Get notified when we publish. No spam.</p>
        <div class="newsletter-placeholder">Coming soon</div>
      </div>

      <div class="sidebar-card">
        <a href="https://notbyai.fyi/hi/token-by-token/" target="_blank" rel="noopener" class="not-by-ai-sidebar">
          <img src="/not-by-ai-dark.png" alt="Written by Humans, Not by AI" class="light-only" />
          <img src="/not-by-ai-light.png" alt="Written by Humans, Not by AI" class="dark-only" />
        </a>
      </div>
    </aside>
  </div>

  <script>
    const input = document.getElementById('search-input') as HTMLInputElement;
    const postList = document.getElementById('post-list');
    if (input && postList) {
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        const items = postList.querySelectorAll('.post-item') as NodeListOf<HTMLElement>;
        items.forEach((item) => {
          const title = item.dataset.title || '';
          const tags = item.dataset.tags || '';
          const author = item.dataset.author || '';
          const desc = item.dataset.desc || '';
          const match = !q || title.includes(q) || tags.includes(q) || author.includes(q) || desc.includes(q);
          item.style.display = match ? '' : 'none';
        });
      });
    }
  </script>
</HomeLayout>
