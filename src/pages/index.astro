---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<HomeLayout title="Home">
  <section class="hero">
    <p class="tagline">
      Notes on machine learning, NLP, and everything in between.<br />
      Learning in public, one concept at a time.
    </p>
  </section>

  <h2>Recent posts</h2>

  {
    posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <div class="post-item">
            <a href={`/posts/${post.id}`} class="post-title">{post.data.title}</a>
            <div class="post-subtitle">
              {post.data.author && (
                <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> {post.data.author}</span>
              )}
              {post.data.author && <span> &middot; </span>}
              <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              {post.data.tags && (
                <span> &middot; <svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg> {post.data.tags.join(', ')}</span>
              )}
              {post.data.description && <br />}
              {post.data.description && <span>{post.data.description}</span>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p>No posts yet. Check back soon!</p>
    )
  }
</HomeLayout>
