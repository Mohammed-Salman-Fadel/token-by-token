---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="All Posts">
  <h1>All posts</h1>

  <div class="search-wrapper">
    <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="search-input" placeholder="Search posts..." class="search-input" />
  </div>

  <div class="post-list" id="post-list">
    {
      posts.map((post) => (
        <div class="post-item" data-title={post.data.title.toLowerCase()} data-tags={(post.data.tags || []).join(' ').toLowerCase()} data-author={(post.data.author || '').toLowerCase()} data-desc={(post.data.description || '').toLowerCase()}>
          <a href={`/posts/${post.id}`} class="post-title">{post.data.title}</a>
          <div class="post-subtitle">
            {post.data.author && (
              <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <a href={`/authors/${post.data.author}`} class="subtle-link">{post.data.author}</a></span>
            )}
            {post.data.author && <span> &middot; </span>}
            <span><svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            {post.data.tags && (
              <span> &middot; <svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg> {post.data.tags.map((tag, i) => (
                <span><a href={`/tags/${tag}`} class="subtle-link">{tag}</a>{i < post.data.tags!.length - 1 ? ', ' : ''}</span>
              ))}</span>
            )}
            {post.data.description && <br />}
            {post.data.description && <span>{post.data.description}</span>}
          </div>
        </div>
      ))
    }
  </div>

  <script>
    const input = document.getElementById('search-input') as HTMLInputElement;
    const postList = document.getElementById('post-list');
    if (input && postList) {
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        const items = postList.querySelectorAll('.post-item') as NodeListOf<HTMLElement>;
        items.forEach((item) => {
          const title = item.dataset.title || '';
          const tags = item.dataset.tags || '';
          const author = item.dataset.author || '';
          const desc = item.dataset.desc || '';
          const match = !q || title.includes(q) || tags.includes(q) || author.includes(q) || desc.includes(q);
          item.style.display = match ? '' : 'none';
        });
      });
    }
  </script>
</BaseLayout>
